# Frontend
NEXT_PUBLIC_RAG_API_BASE_URL=http://localhost:8003

# RAG API
RAG_API_HOST=127.0.0.1
RAG_API_PORT=8003
RAG_API_CORS_ORIGINS=http://localhost:3003,http://localhost:3000

# LLM provider. The first implementation uses mock clients until these are set.
# RAG API reads LLM_* first and falls back to IPHY_* for the institute gateway.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Optional aliases for the IPHY OpenAI-compatible gateway.
IPHY_BASE_URL=https://chat.iphy.ac.cn/api/v1
IPHY_API_KEY=
IPHY_MODEL=deepseek-v4-pro

# Embeddings
# Low-resource default: local all-MiniLM-L6-v2 INT8 ONNX, suitable for 1 vCPU / 1 GiB.
EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BACKEND=onnx
EMBEDDING_ONNX_MODEL_PATH=models/all-MiniLM-L6-v2-int8/onnx/model_quint8_avx2.onnx
EMBEDDING_TOKENIZER_PATH=models/all-MiniLM-L6-v2-int8
EMBEDDING_DIM=384
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_BATCH_SIZE=4
EMBEDDING_MAX_LENGTH=256
EMBEDDING_DEVICE=cpu

# Storage
# The 1 vCPU / 1 GiB default is a local, bounded SQLite memory store. Do not add a
# PostgreSQL container to that host. For production, set this to an external PostgreSQL URL
# and install services/rag-api with the [postgres] extra.
MEMORY_DATABASE_URL=sqlite:///data/runtime/rag-memory.sqlite3
# scripts/dev-rag.sh uses a local PostgreSQL profile by default, independent of this direct
# API fallback. Use these script-specific values to select the local development profile:
# RAG_MEMORY_PROFILE=postgres
# RAG_MEMORY_DATABASE_URL=postgresql://agentweb:agentweb@127.0.0.1:5432/agentweb
# RAG_MEMORY_WORKER_ENABLED=1
# ThinkPad production profile:
# MEMORY_DATABASE_URL=postgresql://agentweb:agentweb@127.0.0.1:5432/agentweb
# MEMORY_CHECKPOINT_BACKEND=postgres
# MEMORY_SEMANTIC_SEARCH_ENABLED=true
MEMORY_CHECKPOINT_BACKEND=auto
MEMORY_POSTGRES_CONNECT_TIMEOUT_SECONDS=3
MEMORY_SHORT_MAX_MESSAGES=10
MEMORY_SUMMARY_MAX_CHARS=1200
MEMORY_MESSAGE_MAX_CHARS=4000
MEMORY_ACTIVE_CONTEXT_MAX_ITEMS=8
MEMORY_LONG_MAX_ITEMS_PER_USER=200
MEMORY_LONG_PROMPT_MAX_ITEMS=8
MEMORY_LONG_PROMPT_MAX_CHARS=1800
MEMORY_SESSION_TTL_DAYS=30
MEMORY_EVENT_TTL_DAYS=90
MEMORY_CLEANUP_INTERVAL_SECONDS=21600
MEMORY_THREAD_ROLLOVER_TURNS=100
MEMORY_SEMANTIC_SEARCH_ENABLED=auto
MEMORY_SEMANTIC_CANDIDATE_LIMIT=24
MEMORY_WORKER_POLL_SECONDS=3

# Legacy PostgreSQL connection variables for the broader platform.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentweb
POSTGRES_USER=agentweb
POSTGRES_PASSWORD=agentweb

# Retrieval
# Use Milvus hybrid retrieval after importing the MiniLM INT8 embeddings.
RETRIEVAL_PROVIDER=milvus-hybrid
GROWTH_RECORDS_PATH=rawData.jsonl

# Milvus hybrid retrieval: BM25 sparse + dense vector + RRF.
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION=growth_records_minilm
MILVUS_TEXT_FIELD=text
MILVUS_SPARSE_FIELD=text_sparse
MILVUS_DENSE_FIELD=text_dense
MILVUS_BM25_TOP_K=50
MILVUS_DENSE_TOP_K=50
MILVUS_RRF_K=60
MILVUS_CONSISTENCY_LEVEL=Bounded

# Deprecated Qdrant placeholders, kept only for compatibility during migration.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=growth_records
