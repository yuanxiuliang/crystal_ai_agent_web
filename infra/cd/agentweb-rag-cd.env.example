# This file is installed outside the Git checkout as /etc/agentweb-rag-cd.env.
# It contains no database credentials. Keep the installed file mode at 0600.

AGENTWEB_REPOSITORY=yuanxiuliang/crystal_ai_agent_web
AGENTWEB_REPOSITORY_URL=https://github.com/yuanxiuliang/crystal_ai_agent_web.git
AGENTWEB_BRANCH=main
AGENTWEB_DEPLOY_ROOT=/home/yuanx/agentweb-rag
AGENTWEB_RELEASES_ROOT=/home/yuanx/agentweb-rag-releases

# The public repository works without a token. Add a fine-grained GitHub token with read-only
# Actions metadata access only if the repository later becomes private or API rate limits matter.
# GITHUB_API_TOKEN=
