# Copy this file to infra/compose/.env.x1c and replace every CHANGE_ME value.
# It contains deployment secrets. Keep the real file mode at 0600 and do not commit it.

COMPOSE_PROJECT_NAME=agentweb-rag

POSTGRES_DB=agentweb
POSTGRES_USER=agentweb
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_POSTGRES_PASSWORD

# The pinned Milvus 2.6 + MinIO standalone pair is validated with these compatibility
# credentials. MinIO remains on the internal rag-data network with no host port.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Set the provider values used by the RAG answering model. Empty values keep the local mock
# client available for private infrastructure smoke tests only.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=mock-growth-rag
LLM_PROVIDER=auto
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Private validation is plain HTTP through SSH port forwarding. Change these two values only
# after the constrained server provides HTTPS for the final public domain.
AUTH_COOKIE_SECURE=false
RAG_API_CORS_ORIGINS=http://127.0.0.1:3003,http://localhost:3003
